                  "});",
                  "",
                  "pm.test('Log item shape is valid when content exists', function () {",
                  "    const json = pm.response.json();",
                  "    if (json.content.length > 0) {",
                  "        const log = json.content[0];",
                  "        pm.expect(log).to.have.property('id');",
                  "        pm.expect(log).to.have.property('requestTime');",
                  "        pm.expect(log).to.have.property('responseTime');",
                  "        pm.expect(log).to.have.property('durationMs');",
                  "        pm.expect(log).to.have.property('method');",
                  "        pm.expect(log).to.have.property('path');",
