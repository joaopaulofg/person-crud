      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Fluxo sugerido:",
          "// 1. Auth / Validate API Key",
          "// 2. Persons / List Persons - Paginated ou Create Person",
          "// 3. Logs / List Request Logs - Paginated",
          "// 4. Auth / Logout"
        ]
      }
    },
