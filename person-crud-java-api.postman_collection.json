        {
          "name": "Create Person",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has person id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.exist;",
                  "    pm.collectionVariables.set('personId', json.id);",
                  "});",
                  "",
                  "pm.test('Response email is normalized', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.email).to.eql('joao.silva@email.com');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"João\",\n  \"lastName\": \"Silva\",\n  \"email\": \"joao.silva@email.com\",\n  \"documentNumber\": \"529.982.247-25\",\n  \"dateOfBirth\": \"1998-05-20\",\n  \"addresses\": [\n    {\n      \"street\": \"Rua das Flores\",\n      \"number\": \"100\",\n      \"complement\": \"Apto 202\",\n      \"neighborhood\": \"Centro\",\n      \"city\": \"Fortaleza\",\n      \"state\": \"CE\",\n      \"zipCode\": \"60000-000\"\n    }\n  ],\n  \"phoneNumbers\": [\n    {\n      \"number\": \"(85) 99999-9999\",\n      \"type\": \"personal\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/persons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons"
              ]
            },
            "description": "Cria uma nova pessoa. O CPF usado é válido para teste e será normalizado pelo backend."
          },
          "response": []
        },
